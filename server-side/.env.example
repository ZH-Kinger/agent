# ============================================================
# GitHub
# ============================================================
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
GITHUB_ORG=wuji-technology

# ============================================================
# 云端 LLM (阿里云 DashScope / Qwen-Max)
# ============================================================
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================
# Jira
# ============================================================
JIRA_URL=https://jira.wuji.tech
JIRA_PAT=xxxxxxxxxxxxxxxx
JIRA_PROJECT_KEY=DEMO
JIRA_ISSUE_TYPE=Task

# ============================================================
# 飞书
# ============================================================
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx
FEISHU_CHAT_ID=oc_xxxxxxxxxxxxxxxx

# ============================================================
# LLM (Review 模块)
# ============================================================
LLM_MODEL=qwen-max
LLM_MAX_TOKENS=2048

# ============================================================
# MCP Server
# ============================================================
MCP_TRANSPORT=http
MCP_PORT=8080
REVIEW_TOKEN=your-secret-token-here
BOOTSTRAP_TOKEN=your-bootstrap-token-here
REPO_TOKENS_FILE=/data/repo_tokens.json

# 审核人持久化文件（格式: {"org/repo": [{"open_id": "ou_xxx", "name": "张三"}]}）
REVIEWERS_FILE=/data/reviewers.json
